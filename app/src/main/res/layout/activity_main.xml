<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cutie 💕"
        android:textColor="#FF6FB5"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"/>

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:src="@mipmap/ic_launcher_round"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:background="#1A0F1A"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="जी बॉस! Cutie आपके हुक्म का इंतज़ार कर रही है... 💋"
            android:textColor="#FFE3F0"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"/>

    </ScrollView>

    <Button
        android:id="@+id/btnListen"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:text="🎤 सुनो क्यूटी"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#FF6FB5"/>

</LinearLayout>
